{
  "manifest_version": 3,
  "name": "imoo-browser",
  "version": "1.0.0",
  "description": "AI 命令行浏览器控制插件 - 监听控制台、网络请求、错误，支持点击、输入等操作",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "debugger", "cookies", "tabs"],
  "host_permissions": ["<all_urls>", "ws://localhost:*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "imoo-browser"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
